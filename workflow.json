    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are a sales qualification assistant.\n\nEvaluate this lead based on:\n- revenue\n- urgency\n- budget\n- clarity of problem\n\nReturn ONLY valid JSON in this exact format:\n\n{\n  \"lead_score\": 0,\n  \"qualification\": \"Hot\",\n  \"ai_summary\": \"short summary\",\n  \"recommended_action\": \"next step\"\n}\n\nRules:\n- lead_score must be an integer from 1 to 10\n- qualification must be one of: Hot, Warm, Cold\n- do not include markdown\n- do not wrap the response in ```json\n\nLead:\nName: {{$json.full_name}}\nBusiness: {{$json.business_type}}\nRevenue: {{$json.monthly_revenue}}\nChallenge: {{$json.biggest_challenge}}\nGoal: {{$json.goal}}\nBudget: {{$json.budget}}\nUrgency: {{$json.urgency}}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        -368,
        16
      ],
      "id": "598d49a5-ebb7-4dec-9171-590ec843048e",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL",
          "name": "YOUR_OPENAI_CREDENTIAL"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "49e71bc3-2dc7-4317-9d91-fc36ca62cf0b",
              "leftValue": "={{$json.status}}",
              "rightValue": "🔥 Priority",
              "operator": {
                "type": "string",
