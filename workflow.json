    {
      "parameters": {
        "jsCode": "// 1. Get AI response safely\nconst raw = $input.first().json.output?.[0]?.content?.[0]?.text || '';\n\n// 2. Clean possible markdown wrappers\nconst cleaned = raw\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\n\n// 3. Parse AI output safely\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  parsed = {\n    lead_score: null,\n    qualification: 'Cold',\n    ai_summary: cleaned || 'Unable to parse AI response.',\n    recommended_action: 'Manual review required.'\n  };\n}\n\n// 4. Get original form data\nconst formData = $('On form submission').first().json;\n\n// 5. Normalize lead score\nlet score = Number(parsed.lead_score);\nif (Number.isNaN(score)) score = 0;\nparsed.lead_score = score;\n\n// 6. STATUS LOGIC (priority routing)\nif (parsed.qualification === 'Hot' && formData.urgency === 'ASAP') {\n  parsed.status = '🔥 Priority';\n} else if (parsed.qualification === 'Hot') {\n  parsed.status = '🟠 High Intent';\n} else if (parsed.qualification === 'Warm') {\n  parsed.status = '🟡 Nurture';\n} else {\n  parsed.status = '🔵 Low Priority';\n}\n\n// 7. VALUE TAGGING (business value)\nif (score >= 8) {\n  parsed.tag = '💰 High Value';\n} else if (score >= 5) {\n  parsed.tag = '⚖️ Medium Value';\n} else {\n  parsed.tag = '🧊 Low Value';\n}\n\n// 8. REVENUE CLASSIFICATION (extra intelligence)\nconst revenue = formData.monthly_revenue || '';\n\nif (revenue.includes('50k') || revenue.includes('100k')) {\n  parsed.revenue_tier = 'High Revenue';\n} else if (revenue.includes('10k')) {\n  parsed.revenue_tier = 'Mid Revenue';\n} else {\n  parsed.revenue_tier = 'Low Revenue';\n}\n\n// 9. URGENCY NORMALIZATION (clean values)\nparsed.urgency_level = formData.urgency === 'ASAP' ? 'High' : 'Normal';\n\n// 10. FINAL MERGE\nreturn [\n  {\n    json: {\n      ...formData,\n      ...parsed\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
